---
/**
 * The dual-spectrum rule: a short two-tone line (blue -> red) used under
 * headings. Purely decorative.
 */
interface Props {
  width?: number;
}

const { width = 76 } = Astro.props;
---

<div class="dual-rule" style={`width:${width}px`} aria-hidden="true">
  <span class="half-build"></span>
  <span class="half-break"></span>
</div>

<style>
  .dual-rule {
    display: flex;
    height: 2px;
    margin-top: 1.1rem;
  }

  .dual-rule span {
    flex: 1;
  }

  .half-build {
    background: var(--build);
  }

  .half-break {
    background: var(--break);
  }
</style>
