---
/**
 * Dark/light toggle. The initial theme is set by an inline script in the
 * layout head (before first paint); this button just flips and persists it.
 */
---

<button id="theme-toggle" type="button" aria-label="Switch color theme">
  <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    transition: color 0.15s ease, border-color 0.15s ease;
    flex-shrink: 0;
  }

  button:hover {
    color: var(--text);
    border-color: var(--muted);
  }

  /* Show the icon of the theme the button switches to. */
  :global(html[data-theme='light']) .icon-sun {
    display: none;
  }

  :global(html:not([data-theme='light'])) .icon-moon {
    display: none;
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');

  function syncUi(): void {
    const current = document.documentElement.dataset.theme;
    btn?.setAttribute(
      'aria-label',
      current === 'light' ? 'Switch to dark theme' : 'Switch to light theme'
    );
    // Keep the browser UI tint in sync (set initially in the layout head).
    document
      .getElementById('meta-theme-color')
      ?.setAttribute('content', current === 'light' ? '#F6F7F9' : '#0C0E12');
  }

  syncUi();

  btn?.addEventListener('click', () => {
    const next =
      document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {
      // Storage blocked; the theme still applies for this page view.
    }
    syncUi();
  });

  // Follow live OS theme changes when the visitor hasn't chosen manually.
  window
    .matchMedia('(prefers-color-scheme: light)')
    .addEventListener('change', (event) => {
      let stored: string | null = null;
      try {
        stored = localStorage.getItem('theme');
      } catch {
        // Storage blocked; treat as no stored preference.
      }
      if (stored === 'light' || stored === 'dark') return;
      document.documentElement.dataset.theme = event.matches ? 'light' : 'dark';
      syncUi();
    });
</script>
